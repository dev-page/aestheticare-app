# Frontend environment variables for the Vite app.
# Copy this file to .env in the project root and fill in the values.
# For a single-project Vercel deployment, `/api` keeps the frontend on the same host
# as the Vercel Function that serves otp-backend.

VITE_OTP_BACKEND_URL=/api
VITE_OTP_API_BASE_URL=/api
VITE_PAYMONGO_PUBLIC_KEY=
VITE_FACE_API_SCRIPT_URL=
VITE_FACE_API_MODEL_URL=
VITE_GOOGLE_MAPS_API_KEY=
VITE_GOOGLE_MAP_ID=
