# Backend environment variables for the OTP/Node server.
# Copy this file to otp-backend/.env and fill in the values.

PORT=3000
SENDGRID_API_KEY=
SENDGRID_SENDER=
PAYMONGO_SECRET_KEY=
PAYMONGO_PUBLIC_KEY=
FRONTEND_BASE_URL=http://localhost:5173
GOOGLE_OAUTH_CLIENT_ID=
