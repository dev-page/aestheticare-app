# Backend environment variables for the OTP/Node server.
# Copy this file to otp-backend/.env and fill in the values.

PORT=3000
SENDGRID_API_KEY=
SENDGRID_SENDER=
PAYMONGO_SECRET_KEY=
PAYMONGO_PUBLIC_KEY=
FRONTEND_BASE_URL=http://localhost:5173
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=
GOOGLE_CALENDAR_ID=primary
FIREBASE_PROJECT_ID=aesthetic-db
FIREBASE_STORAGE_BUCKET=aesthetic-db.firebasestorage.app
# Recommended for Vercel: paste the full service-account JSON as one line, or use base64.
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_SERVICE_ACCOUNT_BASE64=
# For local development only. Cloud Run can use managed credentials instead.
FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccountKey.json
